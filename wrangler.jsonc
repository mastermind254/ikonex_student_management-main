{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ikonex",
  "compatibility_date": "2026-06-05",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
